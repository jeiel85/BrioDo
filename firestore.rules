rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // 유저 설정 (userSettings)
    // =============================================
    match /userSettings/{userId} {
      // 본인 데이터만 읽기/쓰기 허용
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =============================================
    // 할 일 (todos)
    // =============================================
    match /todos/{todoId} {
      // 읽기: 본인 uid가 일치하는 문서만
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;

      // 생성: 인증된 사용자 + uid가 본인과 일치 + 필수 필드 존재
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;

      // 수정: 본인 데이터 + uid 변경 불가
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      // 삭제: 본인 데이터만
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // =============================================
    // 업적 (achievements)
    // =============================================
    match /achievements/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // =============================================
    // AI 사용량 (aiUsage) - 기기당 일일 제한
    // =============================================
    match /aiUsage/{docId} {
      // 읽기: 본인 uid 포함 문서만
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;

      // 쓰기: 본인 uid + 카운트 0~10 범위
      allow write: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && request.resource.data.count <= 10;
    }

    // =============================================
    // 동기화 큐 (syncQueue) - 오프라인 큐 처리용
    // =============================================
    match /syncQueue/{docId} {
      allow read, write: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // =============================================
    // 그 외 모든 경로: 접근 거부 (기본 deny)
    // =============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
